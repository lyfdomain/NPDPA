    output2 = output2.detach().numpy()
    
    
    pre = wet * cosine_similarity(output1, output2)
    

    prr=[]
    trr=[]
    for i in range(len(ind1)):
        prr.append(pre[ind1[i]//12621,ind1[i]%12621])
        trr.append(dti[ind1[i]//12621,ind1[i]%12621])
    
    area= np.sqrt(sklearn.metrics.mean_squared_error(trr, prr))
