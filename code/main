            # 处理每一行数据
            drug_data.append(row)
    drug_data= np.array(drug_data)
    
    val_data = []
    with open("./" + jihe + "/valid.csv", newline='') as csvfile:
        reader = csv.reader(csvfile, delimiter=',', quotechar='"')
        next(reader)
        for row in reader:
            val_data.append(row)
    val_data = np.array(val_data)
    
    #
    dti = np.loadtxt("./" + jihe + "/dti.txt")#.astype(dtype="int64")

    SR = np.loadtxt("./" + jihe + "/DS.txt")
    SP = np.loadtxt('./'+jihe+'/PS.txt')
    
    for i in range(len(SP)):
        SP[i]=SP[i]/SP[i][i]
        for j in range(len(SP[0])):
            if SP[i][j]<0:
                SP[i][j]=0
    
    
    # SR = sim_recon(SR, 3)
    # SP = sim_recon(SP, 3)
    SR = sim_recon(SR, 1/3)
    SP = sim_recon(SP, 1/3)
    
    
    cof1 = np.zeros(SR.shape)
    cof1[SR >= 0.1] = 1
    SR[SR < 0.1] = 0
    
    cof2 = np.zeros(SP.shape)
    cof2[SP >= 0.01] = 1
    SP[SP < 0.01] = 0
    
    
    SR = drug_rowsimm(SR)
    SP = drug_rowsimm(SP)
    
    
    
    dru = np.loadtxt("./" + jihe + "/drug.txt", dtype=str, comments=None)
    pro = np.loadtxt("./" + jihe + "/protein.txt", dtype=str)
    
    drug=list(dru)
    protein=list(pro)
    
    pp=np.loadtxt("./" + jihe + "/esm_PDB2020.txt", delimiter=",")
    tt = np.loadtxt("./PDB2020/mol2vec_pdb2020_rep.txt")
    
    
    ind_val = []
    for i in range(len(val_data)):
        if val_data[i, 0] in drug and val_data[i, 1] in protein:
            ind_val.append([drug.index(val_data[i, 0]), protein.index(val_data[i, 1])])
    
    tr = []
    for i in range(len(ind_val)):
        tr.append(dti[ind_val[i][0], ind_val[i][1]])
    
    auc_max=0
    
    def test(e, f):
        output1 = e.detach().cpu().numpy()
        output2 = f.detach().cpu().numpy()
        pre = wet * cosine_similarity(output1, output2)
        # pre = output1@(output2.T)
        pr = []
        for i in range(len(ind_val)):
            pr.append(pre[ind_val[i][0], ind_val[i][1]])
        return pr
    #
    cof = np.zeros(dti.shape)
    ind = []
    for i in range(len(drug_data)):
        if drug_data[i,0] in drug and drug_data[i,1] in protein:
            ind.append([drug.index(drug_data[i,0]), protein.index(drug_data[i,1])])
    
    for i in range(len(ind)):
        cof[ind[i][0], ind[i][1]] = 1
    
    dti = torch.from_numpy(dti).float().to(device)
    cof = torch.from_numpy(cof).float().to(device)
    x = torch.from_numpy(tt).float().to(device)
    y = torch.from_numpy(pp).float().to(device)
    sr = torch.from_numpy(SR).float().to(device)
    sp = torch.from_numpy(SP).float().to(device)

    input_size = len(tt[0])
    input_size2 = len(pp[0])
    autoencoder = Autoencoder(input_size, input_size2, hidden_size)
    autoencoder = autoencoder.to(device)
    
    model_max = copy.deepcopy(autoencoder)
    # criterion = nn.MSELoss()
    
    criterion2 = AEFSLoss()
    optimizer = optim.Adam(autoencoder.parameters(), lr=leraning_rate)
    

    for epoch in trange(num_epochs):
        autoencoder.train()
        optimizer.zero_grad()
        e, f = autoencoder(x, y, sr, sp)
        # loss1 = criterion2(e, f, dti, cof)
        loss1 = criterion2(e, sr, f, sp, dti, cof)
    
        reg = get_l2reg(autoencoder.parameters())
        loss = 1 * loss1 + 0.00005*reg
    
        loss.backward()
        optimizer.step()
        # print('Epoch [{}/{}], Loss: {:.4f}'.format(epoch + 1, num_epochs, loss.cpu().item()))
    
        autoencoder.eval()
        pr = test(e, f)
        area= np.sqrt(sklearn.metrics.mean_squared_error(tr, pr))
        person, _ = stats.pearsonr(tr, pr)
        spman, _ = stats.spearmanr(tr, pr)
        CI = concordance_index(tr, pr)
        R2 = r2_score(tr, pr)
        RM = get_rm2(tr, pr)
        aps = sklearn.metrics.mean_absolute_error(tr, pr)
        if CI > auc_max:
            auc_max = CI
            model_max = copy.deepcopy(autoencoder)
            # model_max = autoencoder
        if epoch%100==0:
            print(area, aps, person, spman, CI, R2, RM, "AUC_min", auc_max)
    
    torch.save(model_max.cpu(), 'copdb_predti.pth')
    
    
    # model = torch.load('copdb_predti.pth')
    
    # start= time.time()
    
    model = model_max.cpu()
    model.eval()
    
    ind1 = list(np.loadtxt("./"+ jihe +"/index_test.txt").astype(dtype="int64"))
    
    # print(model)
    x=torch.from_numpy(tt).float()
