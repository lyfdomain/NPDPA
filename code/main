def drug_rowsimm(dd):
    mm = np.zeros(dd.shape)
    for i in range(dd.shape[0]):
        # for j in range(dd.shape[1]):
        if np.sum(dd[i, :])!=0:
           mm[i, :] = dd[i, :] / np.sum(dd[i, :])
    mm[mm < 0] = 0
    return mm


def dis_colsimm(dd):
    mm = np.zeros(dd.shape)
    for j in range(dd.shape[1]):
            if np.sum(dd[:, j]) != 0:
                mm[:, j] = dd[:, j] / np.sum(dd[:, j])
    mm[mm < 0] = 0
    return mm

